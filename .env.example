
# Database
POSTGRES_USER=grades
POSTGRES_PASSWORD=change-me
POSTGRES_DB=grades
DATABASE_URL=postgres://grades:change-me@postgres:5432/grades

# Domains
WEB_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com

# Server URLs
SERVER_PUBLIC_URL=https://api.yourdomain.com
BETTER_AUTH_URL=https://api.yourdomain.com
VITE_SERVER_URL=https://api.yourdomain.com
VITE_DEFAULT_ORGANIZATION_SLUG=your-organization

# Auth / Secrets
BETTER_AUTH_SECRET=please-change-me-32chars-min
CORS_ORIGINS=https://app.yourdomain.com
STORAGE_DRIVER=local

# Traefik / Dokploy
TRAEFIK_NETWORK=dokploy-network
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_CERTRESOLVER=letsencrypt

